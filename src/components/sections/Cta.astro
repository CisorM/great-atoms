---
import type { LandingCta } from '../../content/landing/types';

interface Props {
  cta: LandingCta;
}

const { cta } = Astro.props;
---

<section id="contact" class="px-6 py-24">
  <div class="mx-auto max-w-4xl rounded-3xl border border-indigo-400/20 bg-gradient-to-br from-indigo-500/20 via-slate-900 to-slate-950 px-8 py-16 text-center md:px-16">
    <h2 class="text-3xl font-bold tracking-tight text-white md:text-4xl">{cta.title}</h2>
    <p class="mx-auto mt-4 max-w-xl text-lg text-slate-300">{cta.description}</p>
    <a
      href="mailto:hello@great-atoms.com"
      class="mt-8 inline-flex items-center justify-center rounded-full bg-white px-8 py-3.5 text-sm font-semibold text-slate-950 transition-colors hover:bg-slate-100"
    >
      {cta.button}
    </a>
  </div>
</section>
