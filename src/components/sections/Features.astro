---
import type { LandingFeatures } from '../../content/landing/types';

interface Props {
  features: LandingFeatures;
}

const { features } = Astro.props;

const icons = ['⚡', '🌐', '🚀', '🧩'];
---

<section id="features" class="border-t border-white/10 px-6 py-24">
  <div class="mx-auto max-w-6xl">
    <div class="max-w-2xl">
      <h2 class="text-3xl font-bold tracking-tight text-white md:text-4xl">
        {features.title}
      </h2>
      <p class="mt-4 text-lg text-slate-400">{features.subtitle}</p>
    </div>

    <div class="mt-14 grid gap-6 md:grid-cols-2">
      {
        features.items.map((item, index) => (
          <article class="rounded-2xl border border-white/10 bg-white/[0.03] p-8 transition-colors hover:border-indigo-400/30 hover:bg-white/[0.05]">
            <div
              class="mb-5 flex h-12 w-12 items-center justify-center rounded-xl bg-indigo-500/15 text-xl"
              aria-hidden="true"
            >
              {icons[index % icons.length]}
            </div>
            <h3 class="text-xl font-semibold text-white">{item.title}</h3>
            <p class="mt-3 leading-relaxed text-slate-400">{item.description}</p>
          </article>
        ))
      }
    </div>
  </div>
</section>
