---
import type { LandingHero } from '../../content/landing/types';

interface Props {
  hero: LandingHero;
}

const { hero } = Astro.props;
---

<section class="relative overflow-hidden px-6 pb-24 pt-20 md:pb-32 md:pt-28">
  <div
    class="pointer-events-none absolute inset-0 bg-[radial-gradient(ellipse_at_top,_rgba(99,102,241,0.18),_transparent_55%)]"
    aria-hidden="true"
  />

  <div class="relative mx-auto max-w-4xl text-center">
    <p class="mb-6 inline-flex rounded-full border border-indigo-400/30 bg-indigo-500/10 px-4 py-1.5 text-sm font-medium text-indigo-200">
      {hero.eyebrow}
    </p>

    <h1 class="text-4xl font-bold tracking-tight text-white md:text-6xl md:leading-tight">
      {hero.headline}
    </h1>

    <p class="mx-auto mt-6 max-w-2xl text-lg leading-relaxed text-slate-300 md:text-xl">
      {hero.subheadline}
    </p>

    <div class="mt-10 flex flex-col items-center justify-center gap-4 sm:flex-row">
      <a
        href="#contact"
        class="inline-flex w-full items-center justify-center rounded-full bg-indigo-500 px-8 py-3.5 text-sm font-semibold text-white transition-colors hover:bg-indigo-400 sm:w-auto"
      >
        {hero.ctaPrimary}
      </a>
      <a
        href="#features"
        class="inline-flex w-full items-center justify-center rounded-full border border-white/15 bg-white/5 px-8 py-3.5 text-sm font-semibold text-white transition-colors hover:bg-white/10 sm:w-auto"
      >
        {hero.ctaSecondary}
      </a>
    </div>
  </div>
</section>
