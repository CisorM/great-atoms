---
import { localeLabels, type Locale } from '../../i18n/config';
import { getLocalizedPath } from '../../i18n/utils';

interface Props {
  currentLocale: Locale;
  pathname: string;
}

const { currentLocale, pathname } = Astro.props;
---

<div class="flex items-center gap-1 rounded-full border border-white/10 bg-white/5 p-1 text-sm">
  {
    (['es', 'en'] as const).map((locale) => {
      const href = getLocalizedPath(pathname, locale);
      const isActive = locale === currentLocale;

      return (
        <a
          href={href}
          hreflang={locale}
          lang={locale}
          class:list={[
            'rounded-full px-3 py-1.5 font-medium transition-colors',
            isActive
              ? 'bg-white text-slate-950'
              : 'text-slate-300 hover:text-white',
          ]}
          aria-current={isActive ? 'page' : undefined}
          aria-label={`${localeLabels[locale]}${isActive ? ' (actual)' : ''}`}
        >
          {locale.toUpperCase()}
        </a>
      );
    })
  }
</div>
